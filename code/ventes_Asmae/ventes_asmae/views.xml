<odoo>
    <data>
        <menuitem id="amoa_menu_root" name="CA" sequence = "8"/>

        <record id="action_vente" model="ir.actions.act_window">
            <field name="name">Ventes</field>
            <field name="res_model">soujaa.ventes</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_vente" name="Ventes" action="action_vente" parent="amoa_menu_root" sequence="2"/>


        <record id="vente_list" model="ir.ui.view">
            <field name="name">Ventes</field>
            <field name="model">soujaa.ventes</field>
            <field name="arch" type="xml">
                <list string="Ventes">
                    <field name="name"/>
                    <field name="date_facture"/>
                    <field name="montant"/>
                    <field name="chiffredaffaire"/>
                </list>
            </field>
        </record>
        <record id="vente_from" model="ir.ui.view">
            <field name="name">Ventes</field>
            <field name="model">soujaa.ventes</field>
            <field name="arch" type="xml">
                    <form string="ventes">
                        <field name="name"/>
                        <sheet>
                            <group colspan="2" col="4">
                                <group colspan="2" col="2">
                                    <separator string="Données" colspan="2"/>
                                    <field name="date_facture"/>
                                    <field name="montant"/>
                                </group>
                                <group colspan="2" col="2">
                                    <separator string="Indicateur" colspan="2"/>
                                    <field name="chiffredaffaire"/>
                                </group>
                            </group>
                        </sheet>
                    </form>
            </field>
        </record>
    </data>
</odoo>